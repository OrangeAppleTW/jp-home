---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

// =========================================================
// 合作校ごとに差し替えるデータ
// body・features は HTML 文字列。<p><strong><blockquote><ul><li> が使用可能
// =========================================================
const school = {
  // Hero
  name: "教えない英語® プログラミング教室",
  category: "おうちで英語×プログラミング",
  location: "オンライン（全国対応）",
  tags: ["体験レッスンあり", "英語対応", "小学生〜中学生", "マインクラフト"],
  bannerImage: "/images/schools/oshienaieigo.png", // 画像パスを入れると表示、空ならグラデーション

  // 教学理念（経営者の話）
  philosophy: [
    {
      heading: "ゲームばかりしていて困る・・・から、ゲームで専門分野の習得へ",
      body: `
        <p>お子さんがゲームばかりしていて困る・・・そんなお悩みはありませんか？</p>
        <p>なんとかやめさせて、勉強させよう。と思っても、うまくいかずにイライラしてしまいますよね。</p>
        <p>それなら逆転の発想。</p>
        <blockquote>ゲームをやめさせるのではなく、ゲームを積極的に使って、AI時代に必要な論理的思考、問題解決力、そして英語力まで身につけてしまいましょう！</blockquote>
      `,
      image: "",
    },
    {
      heading: "そもそも、英語はただのツール",
      body: `
        <p>これからの時代を生きるお子様に必要なのは、英語力ではなく、英語をツールとして使って<strong>「何ができるか？」</strong>の中身です。</p>
        <p>その「中身」の一つになりえるのが、ゲームから入り、プログラミングを基礎とした<strong>技術開発力</strong>。</p>
      `,
      image: "",
    },
    {
      heading: "スーパー国際人の育成",
      body: `
        <p>私たちコミオ®・スクールでは、スーパー国際人の育成をしています。</p>
        <p>スーパー国際人の定義は、</p>
        <ul>
          <li>① 高いコミュニケーション力（このごく一部が英語）</li>
          <li>② 専門分野</li>
          <li>③ 日本人としてのアイデンティティ</li>
        </ul>
        <p>英語だけできても、それを使って伝える「中身」がないと、せっかくの英語力が活かせず意味がないと考えています。</p>
        <p>プログラミングを基礎とした技術開発力は、その「中身」、<strong>専門分野の育成</strong>なのです。</p>
      `,
      image: "",
    },
    {
      heading: "専門分野は、好きなことから入るのが一番",
      body: `
        <p>好きだからこそ、夢中になれて、好奇心が広がって、自分から学ぶようになる。</p>
        <blockquote>やらされるのではなく、自立して「自分から学ぶ」——これが、上達に最も大切なポイントです。</blockquote>
      `,
      image: "",
    },
    {
      heading: "「教えないプログラミング」で身につく力",
      body: `
        <p>マインクラフトなど、お子さんたちが大好きなゲームから入ります。「ゲームばかりしていて困る・・・」状態から、そのゲームを使って専門分野を習得します。</p>
        <p>プログラミングでAIを使いこなす＆AIを開発することができるようになるだけでなく、AI時代に最も大切な<strong>論理的思考</strong>と<strong>問題解決力</strong>も身につけることができます。</p>
        <p>上位クラスでは、国際資格も取得可能。禁止してもいずれゲームをやっているなら、それを将来使える資格に切り替えませんか？</p>
      `,
      image: "",
    },
  ],

  // 教室特色（HTML）
  features: `
    <ul>
      <li>レッスンはすべて英語での受講も可能（プログラミングと英語を同時に習得）</li>
      <li>オンラインで全国どこからでも受講できる</li>
      <li>小学生〜中学生対象</li>
    </ul>
  `,

  // CTA
  cta: {
    label: "体験レッスンを申し込む",
    href: "https://www.reservestock.jp/inquiry/MDVkMTVmN2U2O",
  },
};
---

<Layout
  title={`${school.name} | OrangeApple プログラミングスクール`}
  description="ゲームばかりしていて困る…そのゲームを使って、AI時代に必要な論理的思考・問題解決力・英語力を身につける「教えないプログラミング」"
>
  <Header />

  <!-- ============ Hero（Tabelog風フルブリードバナー） ============ -->
  <section class="relative min-h-[70vh] flex flex-col justify-end overflow-hidden">

    {school.bannerImage ? (
      <img
        src={school.bannerImage}
        alt={school.name}
        class="absolute inset-0 w-full h-full object-cover"
      />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-800 to-[#004d47]" />
    )}

    <div class="absolute inset-0 bg-black/60" />

    <div class="relative z-10 max-w-4xl mx-auto w-full px-6 pb-12 pt-40">
      <p class="text-[#00c4b3] text-xs font-bold tracking-widest uppercase mb-4">
        {school.category}
      </p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-black text-white leading-tight mb-6">
        {school.name}
      </h1>
      <div class="flex items-center gap-2 text-white/80 text-sm mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        <span>{school.location}</span>
      </div>
      <div class="flex flex-wrap gap-2">
        {school.tags.map((tag) => (
          <span class="text-xs font-bold text-white/90 bg-white/15 border border-white/25 px-3 py-1 rounded-full">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 教学理念（経営者の話） ============ -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-black text-gray-400 tracking-widest uppercase mb-12">
        経営者の理念
      </p>

      <div>
        {school.philosophy.map((section, i) => (
          <div class={i > 0 ? "mt-10" : ""}>

            <h3 class="text-[1.2rem] font-black text-gray-900 mb-3 leading-snug">
              {section.heading}
            </h3>

            {section.image && (
              <img
                src={section.image}
                alt={section.heading}
                class="w-full rounded-xl mb-6 object-cover max-h-64"
              />
            )}

            <div class="prose-school" set:html={section.body} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 教室特色 ============ -->
  <section class="py-20 px-6 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-black text-gray-400 tracking-widest uppercase mb-8">
        教室の特色
      </p>
      <div class="prose-school" set:html={school.features} />
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-[#00c4b3] font-bold text-xs mb-3 tracking-widest uppercase">
        体験レッスン
      </p>
      <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4">
        まずは、<span class="text-[#00c4b3]">体験から</span>。
      </h2>
      <p class="text-gray-500 mb-10 leading-relaxed">
        お子さんがゲームに夢中になる時間を、未来につながる学びの時間へ。
      </p>
      <a
        href={school.cta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-[#00c4b3] hover:bg-[#00a89a] text-white font-black text-lg px-10 py-4 rounded-full transition-colors shadow-lg shadow-[#00c4b3]/30"
      >
        {school.cta.label} →
      </a>
      <p class="mt-8">
        <a href="/" class="text-sm text-gray-500 hover:text-[#00c4b3] transition-colors">
          ← トップへ戻る
        </a>
      </p>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* set:html で挿入されたコンテンツ向けのスタイル */
  .prose-school :global(p) {
    color: #4b5563;
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-school :global(p:last-child) {
    margin-bottom: 0;
  }
  .prose-school :global(strong) {
    color: #1f2937;
    font-weight: 700;
  }
  .prose-school :global(blockquote) {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    padding: 1rem 1.25rem;
    border-left: 4px solid #00c4b3;
    background: #e6faf9;
    border-radius: 0 0.75rem 0.75rem 0;
    font-size: 1rem;
    font-weight: 700;
    color: #0a5c57;
    line-height: 1.5;
  }
  .prose-school :global(ul) {
    margin: 0.75rem 0;
    padding-left: 0;
    list-style: none;
  }
  .prose-school :global(ul li) {
    position: relative;
    padding-left: 1.5rem;
    color: #374151;
    font-weight: 600;
    line-height: 1.75;
    margin-bottom: 0.5rem;
  }
  .prose-school :global(ul li::before) {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    color: #00c4b3;
    font-weight: 900;
    font-size: 0.875rem;
  }
</style>
