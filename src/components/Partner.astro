---
/* Google フォームの URL は公開前に差し替えてください */
const FORM_URL = "https://rebrand.ly/jp-partner";
---

{/* パートナー・講師募集バナー — フッター手前にさりげなく配置 */}
<section id="partner" class="bg-[#e6faf9] border-y border-[#00c4b3]/20">
  <div class="max-w-4xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-5">
    <div class="flex items-center gap-4">
      <span class="text-2xl">🏫</span>
      <div>
        <p class="font-black text-gray-800 text-base">教室パートナー・講師も同時募集中</p>
        <p class="text-gray-500 text-sm mt-0.5">地域でAI教育を広めたい方、講師として活躍したい方へ</p>
      </div>
    </div>
    <a
      href={FORM_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="shrink-0 border-2 border-[#00c4b3] text-[#00c4b3] hover:bg-[#00c4b3] hover:text-white font-bold text-sm px-6 py-2.5 rounded-full transition-colors"
    >
      詳細・応募はこちら →
    </a>
  </div>
</section>
