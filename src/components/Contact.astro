---
---

{/* Contact section — 開講後に復活予定 */}
{false && <section id="contact" class="py-24 px-6 bg-[#00c4b3]">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">
      まず、体験してみてください。
    </h2>
    <p class="text-white/80 text-lg mb-12 leading-relaxed">
      無料体験レッスンで、お子さまがどんな顔でプログラミングと向き合うか、<br class="hidden sm:block" />
      ぜひ見てあげてください。
    </p>

    <!-- フォーム -->
    <form class="bg-white rounded-3xl p-8 text-left space-y-5 shadow-xl">
      <div>
        <label class="block text-sm font-bold text-gray-700 mb-2">お子さまの学年</label>
        <select class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#00c4b3]">
          <option value="">選択してください</option>
          <option>小学1年生</option>
          <option>小学2年生</option>
          <option>小学3年生</option>
          <option>小学4年生</option>
          <option>小学5年生</option>
          <option>小学6年生</option>
          <option>中学1年生</option>
          <option>中学2年生</option>
          <option>中学3年生以上</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-bold text-gray-700 mb-2">保護者のお名前</label>
        <input
          type="text"
          placeholder="山田 太郎"
          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#00c4b3]"
        />
      </div>

      <div>
        <label class="block text-sm font-bold text-gray-700 mb-2">メールアドレス</label>
        <input
          type="email"
          placeholder="example@email.com"
          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#00c4b3]"
        />
      </div>

      <div>
        <label class="block text-sm font-bold text-gray-700 mb-2">
          電話番号 <span class="text-gray-400 font-normal">（任意）</span>
        </label>
        <input
          type="tel"
          placeholder="090-0000-0000"
          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#00c4b3]"
        />
      </div>

      <button
        type="submit"
        class="w-full bg-[#00c4b3] hover:bg-[#00a89a] text-white font-black text-lg py-4 rounded-xl transition-colors shadow-lg shadow-[#00c4b3]/30"
      >
        無料体験レッスンを申し込む
      </button>

      <p class="text-xs text-gray-400 text-center">
        送信後、担当者よりご連絡いたします。
      </p>
    </form>
  </div>
</section>}
