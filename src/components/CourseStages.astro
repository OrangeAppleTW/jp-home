---
const stages = [
  {
    stage: "STAGE 1",
    name: "Minecraft & Roblox",
    taglineJa: "ゲームの世界で、コードを体験する",
    tag: "入門",
    color: "#00c4b3",
    bgColor: "#e6faf9",
    courses: [
      {
        title: "Minecraft Coding",
        subtitle: "Virtual Logic × Redstone Circuits",
        desc: "子どもたちが大好きな3Dの世界でグラフィカルコマンドを使いながら、ロジック・計算思考・レッドストーン回路を学びます。",
        img: "/images/course-minecraft.png",
      },
      {
        title: "Roblox AI Game Design",
        subtitle: "Game Dev × Generative AI",
        desc: "GenAIツールを活用しながらLuaスクリプトの概念を学習。3Dパルクールレベルをデザインし、マルチプレイヤーゲームを公開するところまで挑戦します。",
        img: "/images/course-roblox.png",
      },
    ],
  },
  {
    stage: "STAGE 2",
    name: "Scratch",
    taglineJa: "直感的なビジュアルインターフェースで、ゲームを作る",
    tag: "初級",
    color: "#ffa300",
    bgColor: "#fff7ed",
    courses: [
      {
        title: "Scratchプログラミング（エディタ）",
        subtitle: "ビジュアルブロック × ロジック設計",
        desc: "ブロックを組み合わせるだけでプログラムが作れます。Motion・Events・Controlブロックを使いながら、コードの考え方を直感的に習得します。",
        img: "/images/course-scratch-editor.png",
      },
      {
        title: "Scratchプログラミング（ゲーム制作）",
        subtitle: "キャラクター設計 × ゲーム完成",
        desc: "「動かす」から「創る」へ——自分だけのゲームを完成させる達成感が、次の学習への原動力になります。",
        img: "/images/course-scratch-game.png",
      },
    ],
  },
  {
    stage: "STAGE 3",
    name: "Python & JavaScript",
    taglineJa: "本物のプログラミング言語で、ゲームを開発する",
    tag: "中級 ／ ITS対応",
    color: "#ff5859",
    bgColor: "#fff1f2",
    courses: [
      {
        title: "Python × ゲーム開発",
        subtitle: "Python × アクションゲーム",
        desc: "世界中のエンジニアが使うPythonでゲーム開発に挑戦。ブラウザ上で動くオリジナルの2Dアクションゲームを完成させます。",
        img: "/images/course-python-game.png",
      },
      {
        title: "JavaScript × ブラウザゲーム",
        subtitle: "Canvas API × インタラクティブゲーム",
        desc: "ブラウザで動くゲームをJavaScriptで開発。この段階でMicrosoft認定の国際資格（ITS）の受験が可能です。",
        img: "/images/course-js-game.png",
      },
    ],
  },
  {
    stage: "STAGE 4",
    name: "Web / DB / AI",
    taglineJa: "AIを創るエンジニアへ",
    tag: "上級",
    color: "#9333ea",
    bgColor: "#faf5ff",
    courses: [
      {
        title: "Web / Database 開発",
        subtitle: "Webアプリ × データベース設計",
        desc: "HTML・CSS・データベースを組み合わせたWebアプリ開発を体系的に学びます。実際に動くアプリを完成させながら、エンジニアの基礎を固めます。",
        img: "/images/course-ai-web.png",
      },
      {
        title: "アルゴリズム × AI開発",
        subtitle: "探索・ソート × AIプログラミング",
        desc: "古典的なアルゴリズムを視覚的に理解し実装。さらに自分でAIを組み込んだプログラムの開発まで挑戦します。使う側から、創る側へ。",
        img: "/images/course-algorithm.png",
      },
    ],
  },
];
---

<section id="courses" class="bg-white">
  <!-- セクションヘッダー -->
  <div class="py-24 px-6 text-center">
    <p class="text-[#00c4b3] font-bold text-sm tracking-widest uppercase mb-3">
      コースの流れ
    </p>
    <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4">
      ゲームから始めて、<span class="text-[#00c4b3]">AIクリエイター</span>へ
    </h2>
    <p class="text-gray-500 max-w-xl mx-auto">
      マインクラフトから始まり、段階的にスキルアップ。お子さまのペースで進められます。
    </p>
  </div>

  <!-- 各 Stage：1 Stage = 1 フルワイドブロック、ピン固定でコースを切り替え -->
  {stages.map((s, si) => (
    <div
      class="stage-block w-full min-h-screen flex flex-col md:flex-row overflow-hidden"
      data-stage={si}
      style={`background-color: ${s.bgColor}`}
    >
      <!-- 左：テキスト -->
      <div class="stage-text w-full md:w-1/2 flex flex-col justify-center px-10 py-16 md:py-24">
        <!-- Stage ヘッダー（固定） -->
        <div class="mb-10">
          <p class="text-xs font-black tracking-widest uppercase mb-1" style={`color: ${s.color}`}>
            {s.stage} · {s.tag}
          </p>
          <h3 class="text-3xl sm:text-4xl font-black text-gray-900 mb-2">{s.name}</h3>
          <p class="text-sm font-bold" style={`color: ${s.color}`}>{s.taglineJa}</p>
        </div>

        <!-- コース詳細（スクロールで切り替え） -->
        <div class="relative" style="min-height: 160px;">
          {s.courses.map((c, ci) => (
            <div
              class={`course-detail absolute inset-0 ${ci === 0 ? "opacity-100" : "opacity-0"}`}
              data-course={ci}
            >
              <!-- ドットナビ -->
              <div class="flex gap-2 mb-4">
                {s.courses.map((_, di) => (
                  <span
                    class="dot w-2 h-2 rounded-full transition-colors"
                    style={di === ci ? `background-color: ${s.color}` : "background-color: #d1d5db"}
                  />
                ))}
              </div>
              <p class="text-lg font-black text-gray-900 mb-1">{c.title}</p>
              <p class="text-sm font-bold mb-4" style={`color: ${s.color}`}>{c.subtitle}</p>
              <p class="text-gray-600 leading-relaxed">{c.desc}</p>
            </div>
          ))}
        </div>

        <!-- 装飾：大きなステージ番号 -->
        <p class="mt-16 text-[10rem] font-black leading-none select-none pointer-events-none opacity-[0.04] text-gray-900">
          {si + 1}
        </p>
      </div>

      <!-- 右：画像（スクロールで切り替え） -->
      <div class="relative w-full md:w-1/2 min-h-[50vh] md:min-h-screen overflow-hidden">
        {s.courses.map((c, ci) => (
          <!-- 視差のため画像を縦に120%にし、上下に余白を確保する -->
          <img
            src={c.img}
            alt={c.title}
            class={`course-img absolute left-0 w-full object-cover ${ci === 0 ? "opacity-100" : "opacity-0"}`}
            style="height: 120%; top: -10%;"
            data-course={ci}
          />
        ))}
      </div>
    </div>
  ))}
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>(".stage-block").forEach((block) => {
    const details = block.querySelectorAll<HTMLElement>(".course-detail");
    const imgs = block.querySelectorAll<HTMLElement>(".course-img");
    const courseCount = details.length;

    if (courseCount < 2) return;

    let currentIdx = 0;

    ScrollTrigger.create({
      trigger: block,
      start: "top top",
      end: `+=${(courseCount - 1) * window.innerHeight}`,
      pin: true,
      onUpdate(self) {
        const idx = Math.min(Math.floor(self.progress * courseCount), courseCount - 1);

        // 視差：progress に応じて全画像を y 移動（-30px〜+30px）
        // 符号を反転：下スクロール時に画像が上に動く
        const parallaxY = (0.5 - self.progress) * 60;
        imgs.forEach((img) => gsap.set(img, { y: parallaxY }));

        // コースが変わった時だけ切り替えアニメーション（テキストと画像を同時に）
        if (idx === currentIdx) return;
        currentIdx = idx;

        details.forEach((d, i) => {
          gsap.to(d, {
            opacity: i === idx ? 1 : 0,
            y: i === idx ? 0 : 20,
            duration: 0.5,
            ease: "power2.out",
            overwrite: true,
          });
        });

        imgs.forEach((img, i) => {
          gsap.to(img, {
            opacity: i === idx ? 1 : 0,
            duration: 0.5,
            ease: "power2.out",
            overwrite: true,
          });
        });
      },
    });
  });

  // ステージ登場アニメーション
  document.querySelectorAll<HTMLElement>(".stage-block").forEach((block) => {
    gsap.from(block.querySelector(".stage-text"), {
      x: -60,
      opacity: 0,
      duration: 0.9,
      ease: "power3.out",
      scrollTrigger: {
        trigger: block,
        start: "top 80%",
        toggleActions: "play none none none",
      },
    });
    gsap.from(block.querySelector(".relative.w-full.md\\:w-1\\/2"), {
      x: 60,
      opacity: 0,
      duration: 0.9,
      ease: "power3.out",
      scrollTrigger: {
        trigger: block,
        start: "top 80%",
        toggleActions: "play none none none",
      },
    });
  });
</script>
