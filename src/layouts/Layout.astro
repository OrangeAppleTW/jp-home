---
import "../styles/global.css";
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "OrangeApple プログラミングスクール",
  description = "マインクラフトで始めて、AIを作る側へ。子ども専門のプログラミングスクール。",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- 日文フォント（display=swap でタイムアウト時もシステムフォントでレンダリング） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body class="font-[Noto_Sans_JP] bg-white text-gray-800 antialiased">
    <slot />
  </body>
</html>
